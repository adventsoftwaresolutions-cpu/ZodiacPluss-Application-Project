# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Local environment and secrets. Commit only a redacted .env.example file.
.env
.env.*
!.env.example

# Android signing keys and local signing configuration
*.jks
*.keystore
/android/key.properties

# Apple signing/provisioning files
*.p12
*.mobileprovision

# Firebase configuration should be supplied securely per environment.
/android/app/google-services.json
/ios/Runner/GoogleService-Info.plist

# Local tool and test output
.vscode/settings.json
test-results/
coverage/lcov.info

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
